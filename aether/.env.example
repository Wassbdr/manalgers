# Mem0 API key used by the backend for persistent memory operations.
MEM0_API_KEY=your_mem0_api_key_here

# Optional token used to validate webhook requests.
WEBHOOK_TOKEN=

# Optional comma-separated CORS origins.
CORS_ORIGINS=http://localhost:3000

# External APIs mode:
# - auto: use real APIs when configured; fallback to mock for Mem0 if missing
# - real: force real APIs only
# - mock: force in-memory mock for Mem0
EXTERNAL_SERVICES_MODE=auto

# Optional local tunnel managed by the app at startup.
USE_NGROK=True
NGROK_AUTHTOKEN=your_token_here

# Vapi integration
VAPI_API_KEY=your_vapi_api_key_here
VAPI_BASE_URL=https://api.vapi.ai
# Public URL of this backend that Vapi will POST webhooks to (e.g. ngrok tunnel)
VAPI_SERVER_URL=https://your-tunnel.ngrok.io

# Optional runtime configuration.
HOST=0.0.0.0
PORT=8000
